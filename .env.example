# Copy to `.env` (git-ignored) and fill in real values, or export these as
# real environment variables in dev/test/prod. Nothing here is a real secret.
# See docs/database.md and SECURITY.md for details.

# Which application-{profile}.yml to activate: local | dev | test | prod
SPRING_PROFILES_ACTIVE=local

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/jwt_auth
DB_USERNAME=postgres
DB_PASSWORD=changeme

# JWT signing key — generate with
# com.henheang.securityapi.utils.JwtSecretGenerator#main (64-byte, base64)
JWT_SECRET=

# Gmail SMTP (password reset emails)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Comma-separated Google OAuth2 client IDs allowed as ID-token audience.
# Empty disables Google sign-in.
GOOGLE_CLIENT_IDS=

# CORS / password-reset links
FRONTEND_URL=http://localhost:3000
