{
  "info": {
    "name": "AuthHub - security-api",
    "description": "Requests for security-api (port 8080). Import into Postman along with the AuthHub environment. All responses are wrapped in common-api's ApiResponse envelope.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "mfaToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "permissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phoneNumber\": \"+15551234567\",\n  \"password\": \"StrongP@ssw0rd123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json.data;",
                  "",
                  "if (data && data.mfaRequired) {",
                  "    pm.collectionVariables.set(\"mfaToken\", data.mfaToken);",
                  "    console.log(\"MFA required - mfaToken saved. Call MFA > Verify MFA next.\");",
                  "} else if (data && data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", data.refreshToken);",
                  "    console.log(\"accessToken and refreshToken saved to collection variables.\");",
                  "} else {",
                  "    console.warn(\"Login response did not contain expected token fields.\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"StrongP@ssw0rd123\"\n}"
            }
          }
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/oauth2/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"<google-id-token>\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/user"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\"\n}"
            }
          }
        },
        {
          "name": "Validate Reset Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password?token=<reset-token>",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"],
              "query": [{ "key": "token", "value": "<reset-token>" }]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token>\",\n  \"newPassword\": \"NewStrongP@ss123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<verification-token>\"\n}"
            }
          }
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/resend-verification",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\"\n}"
            }
          }
        },
        {
          "name": "Unlock Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/unlock-account",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<unlock-token>\"\n}"
            }
          }
        },
        {
          "name": "Resend Unlock Link",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/resend-unlock-link",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "MFA",
      "item": [
        {
          "name": "Setup MFA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/mfa/setup"
          }
        },
        {
          "name": "Enable MFA",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/mfa/enable",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Disable MFA",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/mfa/disable",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Verify MFA (login step 2)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/mfa/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mfaToken\": \"{{mfaToken}}\",\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Regenerate Backup Codes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/mfa/backup-codes/regenerate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Update User (self or ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane R. Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phone_number\": \"+15551234567\",\n  \"image_url\": \"https://example.com/avatar.png\",\n  \"email_verified\": true\n}"
            }
          }
        },
        {
          "name": "Delete User (self or ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Unlock User (ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}/unlock"
          }
        }
      ]
    },
    {
      "name": "Admin - Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/roles"
          }
        },
        {
          "name": "Get Role",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/roles/{{roleId}}"
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ROLE_MANAGER\",\n  \"description\": \"Manager role\"\n}"
            }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/roles/{{roleId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ROLE_MANAGER\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/roles/{{roleId}}"
          }
        },
        {
          "name": "Grant Permission to Role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/roles/{{roleId}}/permissions/{{permissionId}}"
          }
        },
        {
          "name": "Revoke Permission from Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/roles/{{roleId}}/permissions/{{permissionId}}"
          }
        }
      ]
    },
    {
      "name": "Admin - Permissions",
      "item": [
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/permissions"
          }
        },
        {
          "name": "Get Permission",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/permissions/{{permissionId}}"
          }
        },
        {
          "name": "Create Permission",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/permissions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resource\": \"TODO\",\n  \"action\": \"READ\",\n  \"description\": \"Read todo items\"\n}"
            }
          }
        },
        {
          "name": "Delete Permission",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/permissions/{{permissionId}}"
          }
        }
      ]
    },
    {
      "name": "Admin - User Roles",
      "item": [
        {
          "name": "List Roles for User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/roles"
          }
        },
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/roles/{{roleId}}"
          }
        },
        {
          "name": "Remove Role from User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/roles/{{roleId}}"
          }
        }
      ]
    },
    {
      "name": "Admin - Audit Logs",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?page=0&size=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "List Audit Logs for User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs/user/{{userId}}?page=0&size=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs", "user", "{{userId}}"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "50" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/public/ping"
          }
        }
      ]
    }
  ]
}
